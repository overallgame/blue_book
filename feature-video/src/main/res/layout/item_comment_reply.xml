<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/reply_avatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/CircleImageStyle"
        tools:src="@drawable/ic_launcher_background" />

    <TextView
        android:id="@+id/reply_nickname"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/video_on_surface"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/reply_like_layout"
        app:layout_constraintStart_toEndOf="@id/reply_avatar"
        app:layout_constraintTop_toTopOf="@id/reply_avatar"
        tools:text="回复者昵称" />

    <TextView
        android:id="@+id/reply_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="2dp"
        android:textColor="@color/video_text_tertiary"
        android:textSize="11sp"
        app:layout_constraintStart_toEndOf="@id/reply_avatar"
        app:layout_constraintTop_toBottomOf="@id/reply_nickname"
        tools:text="1小时前" />

    <LinearLayout
        android:id="@+id/reply_like_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/reply_like_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="点赞"
            android:src="@drawable/like_icon3" />

        <TextView
            android:id="@+id/reply_like_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/video_text_tertiary"
            android:textSize="10sp"
            tools:text="123" />
    </LinearLayout>

    <TextView
        android:id="@+id/reply_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/video_on_surface"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/reply_avatar"
        app:layout_constraintTop_toBottomOf="@id/reply_time"
        tools:text="这是一条回复内容" />

    <TextView
        android:id="@+id/reply_action_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="4dp"
        android:text="回复"
        android:textColor="@color/video_text_secondary"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/reply_avatar"
        app:layout_constraintTop_toBottomOf="@id/reply_content" />

</androidx.constraintlayout.widget.ConstraintLayout>
